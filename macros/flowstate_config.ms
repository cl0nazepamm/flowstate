    logoB64 += "bNb9AAF7qHucdZn/ABy7QM+R5uP7AD+paSAiIgIiICIiAiIgIiICIiAiIgIiICIiAiIgIiICIiAiIgIiICIiAiIgIiICIiAiIgIi"
